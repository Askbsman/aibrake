# Stage 0.3 hosted-beta environment.
# Copy to .env (or your hosting platform's secret store) and fill in.

# ── Networking ───────────────────────────────────────────────────────────
# Default 8080 (not 3000 — avoids local conflicts with Next.js / CRA / Rails
# dev servers, which is a real foot-gun we hit during development).
PORT=8080
NODE_ENV=production

# ── Auth ─────────────────────────────────────────────────────────────────
# optional | required
#   optional  — anyone can call /v1/check; useful for local dev and harness
#   required  — Authorization: Bearer <key> is enforced; the hosted-beta default
AGENT_SPEND_GUARD_AUTH_MODE=required

# Comma-separated list of API keys accepted by the server.
# Recommended format: asg_v1_<24+ random base32 chars> (see DEPLOYMENT.md).
# Any non-empty string is accepted; the format is convention only.
AGENT_SPEND_GUARD_API_KEYS=asg_v1_change_me_for_partner_1,asg_v1_change_me_for_partner_2

# ── Rate limit ───────────────────────────────────────────────────────────
# Per-key sliding window, 60-second bucket. 600 = 10 req/sec/key.
# Anonymous traffic (optional mode + no Bearer) groups under one "anon" bucket.
AGENT_SPEND_GUARD_RATE_LIMIT_PER_KEY_PER_MIN=600

# ── Logging ──────────────────────────────────────────────────────────────
# stdout | jsonl | none
#   stdout  — one JSON line per decision to stdout (default, dev-friendly)
#   jsonl   — append redacted JSON line to AGENT_SPEND_GUARD_LOG_PATH
#   none    — silent (use only when shipping logs via a custom LoggerSink)
AGENT_SPEND_GUARD_LOG_SINK=jsonl
AGENT_SPEND_GUARD_LOG_PATH=./logs/decisions.jsonl

# ── Branding / discovery ─────────────────────────────────────────────────
# Optional. If set, /v1/meta exposes this URL so partner SDKs can self-describe.
AGENT_SPEND_GUARD_SERVICE_NAME=agent-spend-guard
# AGENT_SPEND_GUARD_PUBLIC_URL=https://agent-spend-guard.yourdomain.com

# ── x402 micropayments (Stage 0.7) ───────────────────────────────────────
# When X402_ENABLED=true, AIBrake mounts POST /x402/v1/check as a paid
# resource on Base (USDC) alongside the free Bearer-auth /v1/check.
# Off by default so existing deployments don't accidentally toggle a
# payment requirement.
#
# Pattern mirrors callbsman.com / bsman-ai for consistency between
# author projects — same X402_* env vars, same facilitator URL format.
X402_ENABLED=false
X402_NETWORK=base-sepolia               # "base" for mainnet, "base-sepolia" for testnet
X402_PAY_TO=                            # 0x... wallet address that receives USDC payments
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PRICE_CHECK_USD=0.001              # price per /x402/v1/check call in USD
