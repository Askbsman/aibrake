{
  "name": "aibrake",
  "version": "0.5.6-beta",
  "description": "Loop detection and model stop-loss for paid AI agents. Pre-flight judgment middleware: blocks retry storms, model escalation without evidence, objective drift, and budget breaches before they cost you.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "aibrake": "dist/cli/aibrake.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    },
    "./adapters/openclaw": {
      "types": "./dist/adapters/openclaw/index.d.ts",
      "import": "./dist/adapters/openclaw/index.js"
    },
    "./adapters/coding-agent": {
      "types": "./dist/adapters/coding-agent/index.d.ts",
      "import": "./dist/adapters/coding-agent/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "logs:summary": "tsx src/cli/logs-summary.ts",
    "render:og": "node scripts/render-og-card.mjs",
    "preflight": "node scripts/preflight.mjs",
    "configure": "node scripts/configure-for-deploy.mjs",
    "check:domains": "node scripts/check-domains.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "ai-agents",
    "llm",
    "loop-detection",
    "ai-safety",
    "stop-loss",
    "agent-safety",
    "cost-control",
    "openai",
    "anthropic",
    "claude",
    "gpt",
    "middleware",
    "openclaw",
    "coding-agent",
    "x402"
  ],
  "author": "AIBrake <hello@aibrake.dev> (https://aibrake.dev)",
  "homepage": "https://aibrake.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Askbsman/aibrake.git"
  },
  "bugs": {
    "url": "https://github.com/Askbsman/aibrake/issues"
  },
  "license": "MIT",
  "dependencies": {
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
